# ========================
# LLM / Agent 配置
# ========================

LLM_PROVIDER=deepseek
LLM_MODEL_ID=deepseek-chat
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024
LLM_JSON_MODE=false

# ========================
# 外部 API / 搜索引擎
# ========================

FOFA_BASE_URL=https://fofa.info/api/v1/search/all
FOFA_EMAIL=
FOFA_KEY=

HUNTER_API_KEY=

QUAKE_API_KEY=

SHODAN_API_KEY=

# ========================
# ENScan 配置
# ========================

# enscan Cookie 配置文件路径 (留空自动检测: %GOPATH%/bin/config.yaml → ~/.config/enscan/config.yaml)
# ENSCAN_CONFIG_PATH=

# ========================
# Flask / 安全
# ========================

SECRET_KEY=dev-secret-key
