# ========================
# LLM 模型配置
# ========================

# 当前只实现 openai_compat
LLM_PROVIDER=openai_compat

# 模型名称
LLM_MODEL_ID=deepseek-chat

# API Key
LLM_API_KEY=sk-xxxx

# OpenAI-compatible Base URL
LLM_BASE_URL=https://api.deepseek.com/v1

# 请求超时时间，单位秒
LLM_TIMEOUT=60

# 临时错误重试次数
LLM_MAX_RETRIES=2

# Agent 场景建议为 0
LLM_TEMPERATURE=0

# 单次最大输出 token
LLM_MAX_TOKENS=1024

# 是否启用 JSON Mode，默认关闭
LLM_JSON_MODE=false
